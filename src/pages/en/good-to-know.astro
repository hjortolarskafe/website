---
import BaseLayout from "../../layouts/BaseLayout.astro";
import hoursData from "../../data/openingHours.json";
import Separator from "../../components/separator.astro";

import { getTranslations } from "../../utils/translations";

const lang =  "en";

const t = getTranslations(lang);
---

<BaseLayout title="Good to Know | Hjort Olârs" lang="en">

  <Separator/>

  <section id="opening-hours">
    <h2>{t.openingHours}</h2>
    <ul class="hours-list">
      <li><span>Måndag - Fredag</span> <span>{hoursData.monFri}</span></li>
      <li><span>Lördag</span> <span>{hoursData.saturday}</span></li>
      <li><span>Söndag</span> <span>{hoursData.sunday}</span></li>
    </ul>
  </section>

  <Separator/>

  <section id="location">
    <h2>{t.location}</h2>
    <p>Hagvägen 60, 785 44 Dala-Floda</p>

    <iframe
      src="https://maps.google.com/maps?q=Hagv%C3%A4gen%2060,%20785%2044%20Dala-Floda,%20Sweden&t=&z=15&ie=UTF8&iwloc=&output=embed"
      width="100%"
      height="400"
      style="border:0; border-radius: 8px; margin-top: 1rem;"
      allowfullscreen=""
      loading="lazy"
    >
    </iframe>
  </section>

  <Separator/>

</BaseLayout>