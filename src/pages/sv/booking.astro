---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Separator from "../../components/separator.astro";
import { getTranslations } from "../../utils/translations";

import bookingData from "../../content/booking.json";

const lang = "sv";
const t = getTranslations(lang);
---

<BaseLayout title="Boka Event & Tårtor | Hjort Olârs Café" lang={lang}>
  
  <section id="booking-intro" style="text-align: center;">
    <h2>Boka Event & Beställ Tårtor</h2>
    <p style="max-width: 600px; margin: 0 auto;">
      {bookingData.text_sv}
    </p>
  </section>

  <Separator />

  <section id="booking-form-section">
    <form action="https://api.web3forms.com/submit" method="POST" class="contact-form">

      <input type="hidden" name="access_key" value="your-access-key-here"/>
      <input type="hidden" name="subject" value="Ny förfrågan: Event / Tårta" />
      <input type="hidden" name="redirect" value="https://hjortolars.se/sv/thank-you/" />
      
      <div class="form-group">
        <label for="name">Namn</label>
        <input type="text" id="name" name="Namn" required />
      </div>

      <div class="form-group">
        <label for="email">E-post</label>
        <input type="email" id="email" name="E-post" required />
      </div>

      <div class="form-group">
        <label for="type">Vad gäller förfrågan?</label>
        <select id="type" name="Typ av förfrågan" required>
          <option value="" disabled selected>-- Välj ett alternativ --</option>
          <option value="Tårtbeställning">Tårtbeställning</option>
          <option value="Privat Event / Fest">Privat Event / Fest</option>
          <option value="Företagsmöte">Företagsmöte</option>
          <option value="Annat">Annat</option>
        </select>
      </div>

      <div class="form-group">
        <label for="date">Önskat datum</label>
        <input type="date" id="date" name="Önskat datum" />
      </div>

      <div class="form-group">
        <label for="guests">Antal personer / Bitar</label>
        <input type="number" id="guests" name="Antal personer/bitar" />
      </div>

      <div class="form-group">
        <label for="message">Beskrivning</label>
        <textarea id="message" name="Meddelande" rows="5" placeholder="Vilken sorts tårta önskas? Eller hur ser planerna för ert event ut? Berätta gärna om eventuella allergier." required></textarea>
      </div>

      <button type="submit">Skicka förfrågan</button>
    </form>
  </section>

</BaseLayout>