---
import { getTranslations } from "../utils/translations";

const { title, lang } = Astro.props as {
  title: string;
  lang: "sv" | "en" | "de";
};

const t = getTranslations(lang);

const currentPath = Astro.url.pathname;

function getLangLink(targetLang: string) {
  // This looks at the start of the URL and swaps /sv, /en, or /de for the target language
  return currentPath.replace(/^\/(sv|en|de)/, `/${targetLang}`);
}
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>

    <!-- Google Fonts: Antic Slab for body, Chelsea Market for headings -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Antic+Slab:wght@400;700&family=Chelsea+Market&display=swap" rel="stylesheet" />
  </head>
  <body>


    <nav class="sticky-header">
      <a href={`/${lang}/`} class="header-logo">
        HJoRT ôLARS
      </a>

      <div class="main-nav">
        <a href={`/${lang}/about`}>{t.about}</a>
        <span class="divider">|</span>
        <a href={`/${lang}/menu`}>{t.menu}</a>
        <span class="divider">|</span>
        <a href={`/${lang}/good-to-know`}>{t.goodToKnow}</a>
        <span class="divider">|</span>
        <a href={`/${lang}/afternoon-tea`}>{t.afternoonTea}</a>
        <span class="divider">|</span>
        <a href={`/${lang}/booking`}>{t.booking}</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-section left">
        <div class="social-links">
          <a href="https://www.instagram.com/hjortolarskafe/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <img src="/icons/instagram-logo-bold.svg" alt="Instagram Icon" class="social-icon" />
          </a>
          <a href="https://www.facebook.com/HjortOlars/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <img src="/icons/facebook-logo-bold.svg" alt="Facebook Icon" class="social-icon" />
          </a>
        </div>
      </div>

      <div class="footer-section center">
        <div class="contact-info">
          <a href="mailto:hjortolarskafe@hotmail.com">hjortolarskafe@hotmail.com</a>
          <span class="divider">|</span>
          <a href="tel:0701234567">070-123 45 67</a>
          <span class="divider">|</span>
          <a href="map:Hagvägen 60, 785 44 Dala-Floda">Hagvägen 60, Dala-Floda</a>
        </div>
      </div>
      
      <div class="footer-section right">
        <div class="lang-dropdown-container">
          
          <button class="lang-toggle" id="langToggle">
            
            <span class="custom-globe-wrapper">
              <img src="/icons/globe.svg" alt="Language Icon" class="custom-globe-img" />
              
              <img src={`/icons/globe_${lang}.svg`} alt="Country Flag" class="hover-flag-img" />
            </span>
            
            <span>{t.language}</span>
          </button>

          <nav class="lang-menu" id="langMenu">
            <a href={getLangLink("sv")} class={lang === "sv" ? "active" : ""}>Svenska</a>
            <a href={getLangLink("en")} class={lang === "en" ? "active" : ""}>English</a>
            <a href={getLangLink("de")} class={lang === "de" ? "active" : ""}>Deutsch</a>
          </nav>
          
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Define some cozy café colors */
  :root {
    --bg-color: #eae8e6; /* Warm off-white */
    --text-color: #202020; /* Dark espresso brown for softer contrast */
    --accent-color: #202020; /* Muted forest green */
    --link-color: #5b64a6; /* Warm caramel/wood tone */
    --black: #000000; /* Black for text and accents */
    --white: #ffffff; /* White for backgrounds and accents */
    --h2-color: #202020; /* Dark espresso brown for headings */

    --red-color: #811515; /* Falu-röd */
    --blue-color: #1b48b1; /* Dala-blå */
    --green-color: #208e3f; /* Skogsgrön */
  }

  html[lang="sv"] { --theme-color: var(--red-color); }
  html[lang="en"] { --theme-color: var(--blue-color); }
  html[lang="de"] { --theme-color: var(--green-color); }

  html {
    scroll-behavior: smooth;
    background-color: var(--theme-color);
  }

  /* Basic Reset and Typography */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* Layout constraints to make it readable */
  main {
    max-width: 800px;
    margin: 0 auto; /* Centers the content on the screen */
    padding: 2rem;
    flex: 1 0 auto;
  }


  body {
    font-family: 'Antic Slab', serif;
    font-size: 1.3em;
    font-weight: 400;
    color: var(--text-color);
    line-height: 1.6;
    
    /* The new static background setup */
    background-color: var(--bg-color); /* Fallback color */
    background-image: url("/background/background.png"); /* Replace with your actual image filename! */
    background-size: cover; /* Ensures it covers the whole screen */
    background-position: top center; /* Centers the image */

    /* Keeps your header from covering content */
    padding-top: 4rem; 

    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }




  /* Styling the Sections */
  section {
    margin-bottom: 4rem;
    padding-top: 1rem;
    text-align: center;
  }

  h2 {
    font-family: 'Chelsea Market';
    color: var(--theme-color);
    font-size: 1.8rem;
    margin: 0 auto 1rem auto;
    border-bottom: 2px solid #ebebe3;
    padding-bottom: 0.5rem;
    display: inline-block;
  }

  p {
    margin-bottom: 1rem;
  }

  /* Links and Lists */
  a {
    color: var(--theme-color);
    text-decoration: none;
  }

  a:hover {
    text-decoration: none;
  }

  ul {
    list-style-type: none; /* Removes default bullet points */
    display: flex;
    gap: 1.5rem;
  }







  /* The Sleek Sticky Navigation */
  .sticky-header {
    display: none !important; /* Hides the header on mobile by default */

    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0) 100%);
    z-index: 2000;
    padding: 2rem 2rem; /* Much thinner padding now! */

    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* The new small typography logo */
  .header-logo {
    font-family: 'Chelsea Market';
    font-size: 1.4rem;
    color: var(--bg-color); /* Uses your warm off-white */
    text-decoration: none;
    letter-spacing: 1px;
    white-space: nowrap; /* Prevents the name from breaking into two lines */
    transition: transform 0.2s ease, opacity 0.2s ease;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2); /* Adds a soft drop shadow */
  }

  .header-logo:hover {
    transform: scale(1.05); /* Slight pop when hovered */
    opacity: 0.9;
  }

  .main-nav {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .main-nav a {
    color: var(--bg-color);
    text-decoration: none;
    font-weight: bold;
    font-size: 0.8rem;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    transition: background-color 0.2s;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2); /* Adds a soft drop shadow */
  }

  .main-nav a:hover {
    background-color: var(--text-color);
  }

  .main-nav .divider {
    color: var(--bg-color);
  }




  /* --- The Main Footer --- */
  .site-footer {
    width: 100%;
    background-color: var(--theme-color); 
    border-top: 2px solid #ebebe3;
    
    /* 1. Remove position: fixed, bottom, left, and z-index */
    
    /* 2. Add breathing room! */
    padding: 3rem 2rem 4rem 2rem; /* Top, Right, Bottom, Left */
    margin-top: 5rem; /* Pushes the footer away from the page content */
    
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-section {
    display: flex;
    align-items: center;
    flex: 1; /* Magic trick: Forces all three blocks to take up the exact same amount of space */
  }

  .footer-section.left {
    justify-content: flex-start; /* Pushes socials to the far left */
  }

  .footer-section.center {
    justify-content: center; /* Locks contact info dead center */
  }

  .footer-section.right {
    justify-content: flex-end; /* Pushes language buttons to the far right */
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-icon {
    width: 28px; /* Adjust this number to make the icons bigger or smaller */
    height: 28px;
    object-fit: contain;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .social-links a:hover .social-icon {
    transform: scale(1.15); /* A satisfying little pop/zoom effect */
    opacity: 0.8;
  }

  .social-links a {
    color: var(--white);
    font-weight: bold;
    font-size: 0.9rem;
  }



  /* --- Smart Language Dropdown --- */
  .lang-dropdown-container {
    position: relative; /* Acts as an anchor for the popup menu */
  }

  .lang-toggle {
    background-color: transparent;
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.4);
    padding: 0.4rem 0.8rem;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: bold;
    transition: background-color 0.2s, border-color 0.2s;
  }

  .lang-toggle:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: var(--white);
  }

  /* --- Custom Language Icon & Hover Swap --- */
  .custom-globe-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px; 
    height: 20px;
  }

  /* The default globe image */
  .custom-globe-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 0.2s ease; 
  }

  /* The new SVG flag (pinned directly on top of the globe) */
  .hover-flag-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0; /* Completely invisible by default */
    transition: opacity 0.2s ease;
    pointer-events: none; /* Prevents it from blocking clicks */
  }

  /* THE HOVER MAGIC */
  /* 1. Fade the custom globe out */
  .lang-toggle:hover .custom-globe-img {
    opacity: 0; 
  }
  
  /* 2. Fade the SVG flag in! */
  .lang-toggle:hover .hover-flag-img {
    opacity: 1; 
  }

  /* The Popup Menu */
  .lang-menu {
    position: absolute;
    bottom: 120%; /* Pushes the menu UP, above the footer */
    right: 0;
    background-color: var(--bg-color);
    border: 1px solid #ccc;
    border-radius: 6px;
    display: none; /* Hidden by default */
    flex-direction: column;
    box-shadow: 0 -4px 15px rgba(0, 0, 0, 0.1); /* Shadow points up */
    overflow: hidden;
    min-width: 140px;
  }

  /* When JavaScript adds this class, the menu appears */
  .lang-menu.show {
    display: flex;
  }

  .lang-menu a {
    padding: 0.6rem 1rem;
    color: var(--text-color);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: normal;
    border-bottom: 1px solid #ebebe3;
    transition: background-color 0.2s;
  }

  .lang-menu a:last-child {
    border-bottom: none;
  }

  .lang-menu a:hover {
    background-color: #fff;
  }

  .lang-menu a.active {
    font-weight: bold;
    color: var(--theme-color);
    background-color: rgba(0, 0, 0, 0.03);
  }




  /* --- Footer Contact Info --- */
  .contact-info {
    font-size: 0.85rem;
    color: var(--white);
    opacity: 0.9;
  }

  .contact-info a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .contact-info a:hover {
    opacity: 0.6; /* A soft fade effect when hovered */
    text-decoration: underline;
  }

  .contact-info .divider {
    margin: 0 0.5rem;
    opacity: 0.5;
  }




  /* Contact Form Styles */
  .contact-form {
    max-width: 500px;
    margin: 2rem auto 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    text-align: left;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .contact-form label {
    font-weight: bold;
    color: var(--accent-color);
  }

  .contact-form input,
  .contact-form textarea,
  .contact-form select {
    padding: 0.8rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-family: inherit;
    font-size: 1rem;
    background-color: #fff;
    width: 100%;
  }

  .contact-form input:focus,
  .contact-form textarea:focus,
  .contact-form select:focus {
    outline: 2px solid var(--theme-color);
    border-color: transparent;
  }

  .contact-form button {
    padding: 0.8rem 1.5rem;
    background-color: var(--accent-color);
    color: var(--bg-color);
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .contact-form button:hover {
    background-color: var(--text-color);
  }




  /* --- Opening Hours --- */
  .hours-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 400px;
    margin: 0 auto; /* Centers the list in the middle of the screen */
    padding: 0;
  }

  /* --- Deviating / Override Hours --- */
  .deviating-hours {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 2px dashed #ebebe3;
  }

  .deviating-hours h3 {
    color: var(--red-color); /* Uses your Falu-red to grab attention! */
    font-size: 1.2rem;
    margin-bottom: 0.8rem;
  }

  .closed-notice {
    color: var(--red-color);
    font-weight: bold;
    background-color: rgba(129, 21, 21, 0.05); /* Very soft red background */
    padding: 0.5rem;
    border-radius: 4px;
  }

  .date-highlight {
    opacity: 0.9;
  }

</style>

<script>
  // Wait for the page to load
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('langToggle');
    const menu = document.getElementById('langMenu');

    if (toggle && menu) {
      // Toggle the menu when the button is clicked
      toggle.addEventListener('click', (event) => {
        event.stopPropagation(); // Stops the click from immediately triggering the document click listener below
        menu.classList.toggle('show');
      });

      // Close the menu if the user clicks anywhere else on the page
      document.addEventListener('click', (event) => {
        if (!menu.contains(event.target as Node) && !toggle.contains(event.target as Node)) {
          menu.classList.remove('show');
        }
      });
    }
  });
</script>
